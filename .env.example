# Kopiere diese Datei zu ".env" und trage deinen Schlüssel ein (nur für LOKALE Tests).
# .env ist über .gitignore vom Commit ausgeschlossen und darf niemals hochgeladen werden.

# Pflicht: dein z.ai / GLM API-Key
GLM_API_KEY=hier-deinen-glm-key-einsetzen

# Optional
GLM_MODEL=glm-5.2
SEARCH_RECENCY=oneWeek        # oneDay | oneWeek | oneMonth | oneYear | noLimit
RESULTS_PER_SOURCE=6

# --- E-Mail (optional; nur ausfüllen, wenn du Mailversand willst) ---
# MAIL_TO=empfaenger@example.com
# MAIL_FROM=deinname@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=deinname@gmail.com
# SMTP_PASS=dein-gmail-app-passwort
